# =============================================
# Copter3i Backend - Environment Variables
# Sao chép file này thành .env và điền thông tin thực
# =============================================

# MySQL Connection (VPN server)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=Copter_3i
DB_USER=copter_user
DB_PASSWORD=your_strong_password

# App settings
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=False

# API Security (optional - simple token auth)
API_KEY=your_api_key_here
